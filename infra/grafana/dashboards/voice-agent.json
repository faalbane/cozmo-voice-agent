{
  "dashboard": {
    "id": null,
    "uid": "voice-agent-main",
    "title": "Voice Agent - Real-Time Monitoring",
    "tags": ["voice-agent", "production"],
    "timezone": "browser",
    "refresh": "5s",
    "time": {
      "from": "now-15m",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Concurrent Calls",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(voice_agent_concurrent_calls)",
            "legendFormat": "Active Calls"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Avg E2E Latency",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_e2e_latency_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "Median (ms)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 400 },
                { "color": "red", "value": 600 }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Call Setup Failures",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(voice_agent_call_setup_failures_total[5m])) * 60",
            "legendFormat": "Failures/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Estimated MOS",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_mos_score_bucket[5m])) by (le))",
            "legendFormat": "MOS"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 1,
            "max": 5,
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 3 },
                { "color": "green", "value": 4 }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Pipeline Latency Breakdown",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_stt_duration_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "STT (p50)"
          },
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_llm_ttft_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "LLM TTFT (p50)"
          },
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_tts_ttfb_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "TTS TTFB (p50)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "stacking": { "mode": "normal" }
            }
          }
        }
      },
      {
        "id": 6,
        "title": "E2E Latency Percentiles",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.5, sum(rate(voice_agent_e2e_latency_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(voice_agent_e2e_latency_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(voice_agent_e2e_latency_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Call Volume",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(voice_agent_calls_total[5m])) by (status) * 60",
            "legendFormat": "{{status}}/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": { "mode": "normal" }
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Call Quality - Jitter & Packet Loss",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(voice_agent_jitter_ms_bucket[5m])) by (le))",
            "legendFormat": "Jitter p95 (ms)"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(voice_agent_packet_loss_percent_bucket[5m])) by (le))",
            "legendFormat": "Packet Loss p95 (%)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      }
    ]
  }
}
